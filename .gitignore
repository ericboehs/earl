# Ignore bundler config
/.bundle

# Ignore environment files (but not .envrc.example)
/.env*
!/.envrc.example

# Ignore MCP config (contains env var references to secrets)
/.mcp.json

# Ignore SimpleCov coverage reports
/coverage

# Ignore runtime directories
/tmp/
/storage/
/log/

# Ignore git worktrees
/.worktrees

# Ignore local slash commands and plugin (personal, not committed)
/config/earl-claude-home/.claude/commands/
/config/earl-plugin/

# Ignore built gems
/*.gem
/pkg/
/test-results/
