#!/usr/bin/env ruby
# frozen_string_literal: true

$stdout.sync = true
$stderr.sync = true

original_verbose = $VERBOSE
$VERBOSE = nil
begin
  require "bundler/setup"
rescue LoadError
  # Running as installed gem without Bundler — dependencies resolved by RubyGems
end
$VERBOSE = original_verbose
require_relative "../lib/earl"

case ARGV[0]
when "claude"
  dir = Earl.claude_home
  unless Dir.exist?(dir)
    warn "Claude home directory not found: #{dir}"
    warn "Run 'earl-install' to set up, or set EARL_CLAUDE_HOME"
    exit 1
  end
  caller_dir = Dir.pwd
  plugin_dir = File.join(Earl.config_root, "plugin")
  Dir.chdir(dir)
  cmd = ["claude", "--add-dir", caller_dir]
  cmd.push("--plugin-dir", plugin_dir) if Dir.exist?(plugin_dir)
  cmd.concat(ARGV.drop(1))
  begin
    Kernel.exec(*cmd)
  rescue Errno::ENOENT
    warn "claude not found — is Claude Code installed?"
    exit 127
  end
when "heartbeat", "thread"
  require_relative "../lib/earl/cli"
  Earl::Cli.run(ARGV)
  exit 0
when "home"
  puts Earl.claude_home
  exit 0
when "exec"
  dir = Earl.claude_home
  cmd = ARGV.drop(1)
  if cmd.empty?
    puts dir
    exit 0
  end
  unless Dir.exist?(dir)
    warn "Claude home directory not found: #{dir}"
    warn "Run 'earl-install' to set up, or set EARL_CLAUDE_HOME"
    exit 1
  end
  Dir.chdir(dir)
  begin
    Kernel.exec(*cmd)
  rescue Errno::ENOENT
    warn "Command not found: #{cmd.first}"
    exit 127
  rescue Errno::EACCES
    warn "Permission denied: #{cmd.first}"
    exit 126
  end
when "restart"
  unless File.exist?(Earl::PidFile.path)
    warn "No PID file found at #{Earl::PidFile.path} — is EARL running?"
    exit 1
  end

  pid = File.read(Earl::PidFile.path).strip.to_i
  begin
    Process.kill("HUP", pid)
    puts "Sent SIGHUP to EARL (pid #{pid})"
  rescue Errno::ESRCH
    warn "Process #{pid} not found — removing stale PID file"
    File.delete(Earl::PidFile.path)
    exit 1
  rescue Errno::EPERM
    warn "Cannot signal process #{pid} — owned by another user"
    exit 1
  end
  exit 0
when "update"
  repo_dir = File.expand_path("..", __dir__)
  Dir.chdir(repo_dir) do
    system("git", "pull", "--ff-only") || warn("git pull failed")
    system({ "RUBYOPT" => "-W0" }, "bundle", "install", "--quiet") || warn("bundle install failed")
  end
  puts "Updated. Run 'earl restart' to apply."
  exit 0
when /\A[a-z]/
  warn "Unknown command: #{ARGV[0]}"
  warn "Available commands: claude, exec, heartbeat, home, restart, thread, update"
  exit 1
end

Earl.logger.level = ENV["EARL_DEBUG"] ? Logger::DEBUG : Logger::INFO
Earl.logger.info "Starting EARL..."
Earl::PidFile.check!
Earl::PidFile.write!
at_exit { Earl::PidFile.cleanup! }
runner = Earl::Runner.new
runner.start
